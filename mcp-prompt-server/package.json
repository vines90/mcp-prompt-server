{
  "name": "mcp-prompt-server",
  "version": "3.0.0",
  "description": "基于AI咖平台的MCP服务器，支持个人提示词库访问和身份验证",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:public": "node src/index-public.js",
    "dev": "nodemon src/index.js",
    "dev:public": "nodemon src/index-public.js",
    "test": "node --env-file=.env src/index.js",
    "inspect": "node scripts/inspect_db.js",
    "check": "node scripts/check_db.js",
    "verify": "node verify-server.js",
    "test-mcp": "node test-mcp-client.js"
  },
  "keywords": [
    "mcp",
    "claude",
    "prompt",
    "ai",
    "database",
    "postgresql",
    "ai-prompter",
    "authentication"
  ],
  "author": "AI咖团队",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "pg": "^8.11.3",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/mcp-prompt-server.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/mcp-prompt-server/issues"
  },
  "homepage": "https://www.aiprompter.cc"
}
